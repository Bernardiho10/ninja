<header class="header">
  <div class="header-container">
    <div class="header-left">
      <!-- Mobile hamburger toggle -->
      <button id="mobile-menu-toggle" class="btn-icon mobile-only" title="Menu">
        <i class="ph-duotone ph-list text-lg"></i>
      </button>
      
      <!-- Mobile Logo -->
      <a href="/" class="header-logo mobile-only">
        <div class="logo-box">N</div>
        <span class="logo-text">NINJA</span>
      </a>
    </div>

    <div class="header-actions">
      <button id="theme-toggle" class="btn-icon" title="Toggle Theme">
        <i class="ph-duotone ph-moon text-lg dark-hidden"></i>
        <i class="ph-duotone ph-sun text-lg light-hidden"></i>
      </button>

      <div class="user-profile">
        <div class="user-info desktop-only">
          <span class="user-name">Bernardiho</span>
          <span class="user-role">Admin Account</span>
        </div>
        <div class="user-avatar-circle">BH</div>
      </div>
    </div>
  </div>
</header>
